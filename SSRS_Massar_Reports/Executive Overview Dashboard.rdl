  <DataSets>
    <DataSet Name="KPI_Summary">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Dataset 1: KPI Summary
SELECT 
    COUNT(*) AS total_rides,
    SUM(CASE WHEN is_completed = 1 THEN 1 ELSE 0 END) AS completed_rides,
    SUM(CASE WHEN is_cancelled = 1 THEN 1 ELSE 0 END) AS cancelled_rides,
    ROUND(
        100.0 * SUM(CASE WHEN is_completed = 1 THEN 1 ELSE 0 END) 
        / NULLIF(COUNT(*), 0), 1
    ) AS completion_rate,
    SUM(net_revenue) AS net_revenue,
    ROUND(AVG(CAST(minutes_to_accept AS FLOAT)), 2) AS avg_accept_minutes,
    COUNT(DISTINCT user_key) AS active_riders
FROM marts.fact_rides
-- التعديل بالاسم الصحيح للعمود: requested_date_key
WHERE requested_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND requested_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112);</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="total_rides">
          <DataField>total_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="completed_rides">
          <DataField>completed_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="cancelled_rides">
          <DataField>cancelled_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="completion_rate">
          <DataField>completion_rate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="net_revenue">
          <DataField>net_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_accept_minutes">
          <DataField>avg_accept_minutes</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="active_riders">
          <DataField>active_riders</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="RevenueByMonth">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Revenue by Month (Fixed with Date Filters)
SELECT
    d.year,
    DATENAME(month, d.full_date) AS month_name,
    d.month_number,
    SUM(r.net_revenue)           AS net_revenue,
    COUNT(*)                     AS ride_count
FROM marts.fact_rides r
JOIN marts.dim_date d ON r.completed_date_key = d.date_key
WHERE r.is_completed = 1
  AND r.completed_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.completed_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY d.year, DATENAME(month, d.full_date), d.month_number
ORDER BY d.year, d.month_number;</CommandText>
      </Query>
      <Fields>
        <Field Name="year">
          <DataField>year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="month_name">
          <DataField>month_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="month_number">
          <DataField>month_number</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="net_revenue">
          <DataField>net_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="RidesByGovernorate">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>--Rides by Governorate

SELECT
    g.governorate_name_en,
    COUNT(*)            AS ride_count,
    SUM(r.net_revenue)  AS revenue
FROM marts.fact_rides r
JOIN marts.dim_geography g ON r.pickup_zone_key = g.zone_key
WHERE r.is_completed = 1
GROUP BY g.governorate_name_en
ORDER BY ride_count DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="governorate_name_en">
          <DataField>governorate_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="revenue">
          <DataField>revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
