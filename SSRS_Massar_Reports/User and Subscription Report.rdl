  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="SmartTransportDWH">
      <DataSourceReference>SmartTransportDWH</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>60903771-9944-4e2b-856f-75bda4e87c97</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Monthly_Active_Riders_over_Time">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    d.year,
    DATENAME(month, MIN(d.full_date))   AS month_name,
    d.month_number,
    COUNT(DISTINCT r.user_key)           AS monthly_active_riders,
    COUNT(DISTINCT
        CASE
            WHEN prev.first_ride_month = d.month_number
             AND prev.first_ride_year  = d.year
            THEN r.user_key
        END
    )                                    AS new_riders
FROM marts.fact_rides r
JOIN marts.dim_date d
    ON r.completed_date_key = d.date_key
LEFT JOIN (
    -- first ever completed ride per user
    SELECT
        r2.user_key,
        d2.year  AS first_ride_year,
        d2.month_number AS first_ride_month
    FROM marts.fact_rides r2
    JOIN marts.dim_date d2
        ON r2.completed_date_key = d2.date_key
    WHERE r2.is_completed = 1
) prev
    ON prev.user_key = r.user_key
WHERE r.is_completed = 1
  AND d.year = @Year
GROUP BY
    d.year,
    d.month_number          -- ← group by month number ONLY, not full_date
ORDER BY
    d.month_number</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="year">
          <DataField>year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="month_name">
          <DataField>month_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="month_number">
          <DataField>month_number</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="monthly_active_riders">
          <DataField>monthly_active_riders</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="new_riders">
          <DataField>new_riders</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Subscription_Status_Breakdown">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    sp.plan_name_en,
    us.status,
    COUNT(*)                                AS subscriber_count,
    SUM(us.locked_monthly_price_egp)        AS mrr_contribution,
    AVG(us.duration_days)                   AS avg_duration_days
FROM marts.fact_user_subscriptions us
JOIN marts.dim_subscription_plan sp ON us.plan_key = sp.plan_key
GROUP BY sp.plan_name_en, us.status
ORDER BY subscriber_count DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="plan_name_en">
          <DataField>plan_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="status">
          <DataField>status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="subscriber_count">
          <DataField>subscriber_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="mrr_contribution">
          <DataField>mrr_contribution</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_duration_days">
          <DataField>avg_duration_days</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="User_Role_Distribution">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    user_role,
    COUNT(*) AS user_count
FROM marts.dim_user
GROUP BY user_role</CommandText>
      </Query>
      <Fields>
        <Field Name="user_role">
          <DataField>user_role</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="user_count">
          <DataField>user_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Top_Riders">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT TOP 20
    u.full_name_en,
    COUNT(r.ride_key)           AS total_rides,
    SUM(r.net_revenue)          AS total_spend,
    AVG(rt.score)               AS avg_rating_given
FROM marts.fact_rides r
JOIN marts.dim_user u ON r.user_key = u.user_key
LEFT JOIN marts.fact_ride_ratings rt
    ON rt.rater_user_key = r.user_key
    AND rt.rater_role = 'Passenger'
WHERE r.is_completed = 1
GROUP BY u.full_name_en
ORDER BY total_rides DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="full_name_en">
          <DataField>full_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="total_rides">
          <DataField>total_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_spend">
          <DataField>total_spend</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_rating_given">
          <DataField>avg_rating_given</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
