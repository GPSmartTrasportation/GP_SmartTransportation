  <DataSources>
    <DataSource Name="SmartTransportDWH">
      <DataSourceReference>SmartTransportDWH</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1966c197-ecd7-4e8e-8b79-5d61893b4fb8</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Promo_Performance">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    pc.code,
    pc.discount_type,
    pc.discount_value,
    COUNT(pcr.redemption_key)           AS total_redemptions,
    SUM(pcr.discount_amount_applied)    AS total_discount_given,
    SUM(r.net_revenue)                  AS revenue_from_promo_rides,
    ROUND(
        SUM(r.net_revenue)
        / NULLIF(SUM(pcr.discount_amount_applied), 0)
    , 2)                                AS promo_roi
FROM marts.fact_promo_code_redemptions pcr
JOIN marts.dim_promo_code pc ON pcr.promo_code_key = pc.promo_code_key
LEFT JOIN marts.fact_rides r ON pcr.ride_id = r.ride_id
GROUP BY pc.code, pc.discount_type, pc.discount_value
ORDER BY total_redemptions DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="code">
          <DataField>code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="discount_type">
          <DataField>discount_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="discount_value">
          <DataField>discount_value</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="total_redemptions">
          <DataField>total_redemptions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_discount_given">
          <DataField>total_discount_given</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="revenue_from_promo_rides">
          <DataField>revenue_from_promo_rides</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="promo_roi">
          <DataField>promo_roi</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Rating_Distribution">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    rt.score,
    rt.rater_role,
    COUNT(*) AS rating_count
FROM marts.fact_ride_ratings rt
GROUP BY rt.score, rt.rater_role
ORDER BY rt.rater_role, rt.score DESC
</CommandText>
      </Query>
      <Fields>
        <Field Name="score">
          <DataField>score</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="rater_role">
          <DataField>rater_role</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="rating_count">
          <DataField>rating_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Avg_Driver_Rating_by_Governorate">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    g.governorate_name_en,
    AVG(CAST(rt.score AS FLOAT)) AS avg_driver_rating,
    COUNT(rt.rating_key) AS rating_count
FROM marts.fact_ride_ratings rt
JOIN marts.fact_rides r  ON rt.ride_id = r.ride_id
JOIN marts.dim_geography g ON r.pickup_zone_key = g.zone_key
WHERE rt.rater_role = 'Passenger'
GROUP BY g.governorate_name_en
ORDER BY avg_driver_rating DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="governorate_name_en">
          <DataField>governorate_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="avg_driver_rating">
          <DataField>avg_driver_rating</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="rating_count">
          <DataField>rating_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Rating_Trend_over_Time">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    d.year,
    DATENAME(month, MIN(d.full_date))   AS month_name,
    d.month_number,
    AVG(CASE WHEN rt.rater_role = 'Passenger'
             THEN CAST(rt.score AS FLOAT) END)  AS avg_driver_rating,
    AVG(CASE WHEN rt.rater_role = 'Driver'
             THEN CAST(rt.score AS FLOAT) END)  AS avg_rider_rating,
    COUNT(rt.rating_key)                        AS total_ratings
FROM marts.fact_ride_ratings rt
JOIN marts.dim_date d ON rt.rating_date_key = d.date_key
GROUP BY d.year, d.month_number
ORDER BY d.year, d.month_number</CommandText>
      </Query>
      <Fields>
        <Field Name="year">
          <DataField>year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="month_name">
          <DataField>month_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="month_number">
          <DataField>month_number</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="avg_driver_rating">
          <DataField>avg_driver_rating</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_rider_rating">
          <DataField>avg_rider_rating</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="total_ratings">
          <DataField>total_ratings</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
