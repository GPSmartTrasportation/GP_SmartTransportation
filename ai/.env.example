# Copy to ai/.env and fill in values. Never commit .env.

# --- LLM provider: openai | azure ---
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI (when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
# Either endpoint format works (code auto-detects v1):
#   https://your-resource.openai.azure.com/
#   https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDINGS=text-embedding-3-small
# AZURE_OPENAI_USE_V1=yes

# SQL Server (read-only user recommended)
DB_SERVER=localhost
DB_NAME=GP_SmartTransportDWH
DB_SCHEMA=semantic
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUSTED_CONNECTION=yes
# When DB_TRUSTED_CONNECTION=no:
DB_UID=
DB_PWD=

# Query limits
MAX_QUERY_ROWS=500
SQL_QUERY_TIMEOUT_SECONDS=30

# Optional: published Power BI report URL for sidebar link
POWERBI_REPORT_URL=
