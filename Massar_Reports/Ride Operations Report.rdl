  <DataSets>
    <DataSet Name="RidesByStatus_Day">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--Rides by Status and Day
SELECT d.full_date, d.day_name, d.is_weekend, 
r.current_status AS ride_status
, COUNT(*) AS ride_count
FROM marts.fact_rides r
JOIN marts.dim_date d ON r.requested_date_key = d.date_key
WHERE r.requested_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.requested_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY d.full_date, d.day_name, d.is_weekend, r.current_status
ORDER BY d.full_date</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="full_date">
          <DataField>full_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="day_name">
          <DataField>day_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="is_weekend">
          <DataField>is_weekend</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="ride_status">
          <DataField>ride_status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="RidesByDayPeriod">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--Rides by Period of Day

SELECT
    t.period_of_day,
    t.is_peak_hour,
    COUNT(*)                            AS total_rides,
    AVG(r.minutes_to_accept)            AS avg_accept_min,
    AVG(r.actual_duration_minutes)      AS avg_duration_min,
    ROUND(100.0 *
        SUM(CASE WHEN r.is_completed = 1 THEN 1 ELSE 0 END)
        / NULLIF(COUNT(*), 0), 1)       AS completion_rate
FROM marts.fact_rides r
JOIN marts.dim_time t ON r.requested_time_key = t.time_key
WHERE r.requested_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  
AND r.requested_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY t.period_of_day, t.is_peak_hour</CommandText>
      </Query>
      <Fields>
        <Field Name="period_of_day">
          <DataField>period_of_day</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="is_peak_hour">
          <DataField>is_peak_hour</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="total_rides">
          <DataField>total_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="avg_accept_min">
          <DataField>avg_accept_min</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="avg_duration_min">
          <DataField>avg_duration_min</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="completion_rate">
          <DataField>completion_rate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CancellationsByReason">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    c.reason_title,
    c.applies_to         AS cancelled_by,
    COUNT(*)             AS cancellation_count,
    ROUND(100.0 * COUNT(*) /
        NULLIF(SUM(COUNT(*)) OVER(), 0), 1) AS pct_of_total
FROM marts.fact_rides r
JOIN marts.dim_cancellation_reason c
    ON r.cancellation_reason_key = c.cancellation_reason_key
WHERE r.is_cancelled = 1
AND r.requested_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  
AND r.requested_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY c.reason_title, c.applies_to
ORDER BY cancellation_count DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="reason_title">
          <DataField>reason_title</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cancelled_by">
          <DataField>cancelled_by</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cancellation_count">
          <DataField>cancellation_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="pct_of_total">
          <DataField>pct_of_total</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AvgAcceptTimebyZone">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Governorate">
            <Value>=Parameters!Governorate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    g.governorate_name_en,
    g.city_name_en,
    AVG(r.minutes_to_accept)        AS avg_accept_minutes,
    COUNT(*)                        AS ride_count
FROM marts.fact_rides r
JOIN marts.dim_geography g ON r.pickup_zone_key = g.zone_key
WHERE r.minutes_to_accept &gt; 0
  AND r.requested_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.requested_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
  AND g.governorate_name_en = @Governorate
GROUP BY g.governorate_name_en, g.city_name_en
ORDER BY avg_accept_minutes DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="governorate_name_en">
          <DataField>governorate_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="city_name_en">
          <DataField>city_name_en</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="avg_accept_minutes">
          <DataField>avg_accept_minutes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
