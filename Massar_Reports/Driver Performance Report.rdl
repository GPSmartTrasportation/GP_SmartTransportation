  <DataSources>
    <DataSource Name="SmartTransportDWH">
      <DataSourceReference>SmartTransportDWH</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>65a31916-b1b6-44b5-82c9-b957bd732e4d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Driver_Summary">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DriverId">
            <Value>=Parameters!DriverId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    u.full_name_en AS driver_name,
    d.driver_id,
    d.military_service_status,
    d.is_license_valid,
    d.is_background_check_valid,
    COUNT(DISTINCT s.session_key) AS total_sessions,
    SUM(s.duration_minutes) AS total_online_minutes,
    SUM(s.completed_ride_count) AS completed_rides,
    SUM(s.total_revenue) AS total_earnings,
    AVG(rt.score) AS avg_rating
FROM marts.dim_driver d
JOIN marts.dim_user u ON d.driver_id = u.user_id
LEFT JOIN marts.fact_sessions s ON s.driver_key = d.driver_key
LEFT JOIN marts.fact_ride_ratings rt ON rt.rated_user_key = u.user_key AND rt.rater_role = 'Passenger'
WHERE (@DriverId IS NULL OR d.driver_id = @DriverId) -- ده اللي هيخلي الـ Parameter يشتغل
GROUP BY u.full_name_en, d.driver_id, d.military_service_status, d.is_license_valid, d.is_background_check_valid
ORDER BY total_earnings DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="driver_name">
          <DataField>driver_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="driver_id">
          <DataField>driver_id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="military_service_status">
          <DataField>military_service_status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="is_license_valid">
          <DataField>is_license_valid</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="is_background_check_valid">
          <DataField>is_background_check_valid</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="total_sessions">
          <DataField>total_sessions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_online_minutes">
          <DataField>total_online_minutes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="completed_rides">
          <DataField>completed_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_earnings">
          <DataField>total_earnings</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_rating">
          <DataField>avg_rating</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Sessions_Over_Time">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    d.full_date,
    COUNT(s.session_key)            AS session_count,
    SUM(s.duration_minutes)         AS total_online_minutes,
    SUM(s.completed_ride_count)     AS completed_rides
FROM marts.fact_sessions s
JOIN marts.dim_date d
    ON CAST(s.online_at AS DATE) = d.full_date
GROUP BY d.full_date
ORDER BY d.full_date</CommandText>
      </Query>
      <Fields>
        <Field Name="full_date">
          <DataField>full_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="session_count">
          <DataField>session_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_online_minutes">
          <DataField>total_online_minutes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="completed_rides">
          <DataField>completed_rides</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Driver_Compliance_Summary">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <CommandText>SELECT
    SUM(CASE WHEN is_license_valid = 1
         AND is_background_check_valid = 1 THEN 1 ELSE 0 END) AS fully_compliant,
    SUM(CASE WHEN is_license_valid = 0     THEN 1 ELSE 0 END) AS expired_license,
    SUM(CASE WHEN is_background_check_valid = 0 THEN 1 ELSE 0 END) AS expired_bg_check,
    COUNT(*) AS total_drivers
FROM marts.dim_driver</CommandText>
      </Query>
      <Fields>
        <Field Name="fully_compliant">
          <DataField>fully_compliant</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="expired_license">
          <DataField>expired_license</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="expired_bg_check">
          <DataField>expired_bg_check</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_drivers">
          <DataField>total_drivers</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
