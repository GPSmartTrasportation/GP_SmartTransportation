  <DataSets>
    <DataSet Name="RevenueBreakdown">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    d.year,
    d.month_number,
    DATENAME(month, DATEFROMPARTS(d.year, d.month_number, 1)) AS month_name,
    SUM(r.amount) AS gross_revenue,
    SUM(r.net_revenue) AS net_revenue,
    SUM(r.driver_earning_amount) AS driver_earnings,
    SUM(r.platform_commission_amount) AS platform_commission,
    SUM(r.subscription_discount_amount) AS subscription_discounts,
    SUM(r.promo_discount_amount) AS promo_discounts,
    SUM(r.refund_amount) AS refunds
FROM marts.fact_rides r
JOIN marts.dim_date d ON r.completed_date_key = d.date_key
WHERE r.is_completed = 1
  AND r.completed_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.completed_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY d.year, d.month_number
ORDER BY d.year, d.month_number</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="year">
          <DataField>year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="month_number">
          <DataField>month_number</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="month_name">
          <DataField>month_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="gross_revenue">
          <DataField>gross_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="net_revenue">
          <DataField>net_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="driver_earnings">
          <DataField>driver_earnings</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="platform_commission">
          <DataField>platform_commission</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="subscription_discounts">
          <DataField>subscription_discounts</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="promo_discounts">
          <DataField>promo_discounts</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="refunds">
          <DataField>refunds</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Revenue_by_Vehicle_Type">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    p.preference_name,
    p.domain_name,
    COUNT(*) AS ride_count,
    SUM(r.net_revenue) AS net_revenue,
    AVG(r.amount) AS avg_fare
FROM marts.fact_rides r
JOIN marts.dim_preference p ON r.preference_key = p.preference_key
WHERE r.is_completed = 1
  AND r.completed_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.completed_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY p.preference_name, p.domain_name
ORDER BY net_revenue DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="preference_name">
          <DataField>preference_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="domain_name">
          <DataField>domain_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="net_revenue">
          <DataField>net_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_fare">
          <DataField>avg_fare</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Discount_Impact">
      <Query>
        <DataSourceName>SmartTransportDWH</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    CASE
        WHEN r.subscription_discount_amount &gt; 0 AND r.promo_discount_amount &gt; 0 THEN 'Both'
        WHEN r.subscription_discount_amount &gt; 0 THEN 'Subscription only'
        WHEN r.promo_discount_amount &gt; 0 THEN 'Promo only'
        ELSE 'No discount'
    END AS discount_type,
    COUNT(*) AS ride_count,
    SUM(r.net_revenue) AS net_revenue,
    AVG(r.amount) AS avg_gross_fare
FROM marts.fact_rides r
WHERE r.is_completed = 1
  AND r.completed_date_key &gt;= CONVERT(VARCHAR(8), CAST(@StartDate AS DATE), 112)
  AND r.completed_date_key &lt;= CONVERT(VARCHAR(8), CAST(@EndDate AS DATE), 112)
GROUP BY 
    CASE
        WHEN r.subscription_discount_amount &gt; 0 AND r.promo_discount_amount &gt; 0 THEN 'Both'
        WHEN r.subscription_discount_amount &gt; 0 THEN 'Subscription only'
        WHEN r.promo_discount_amount &gt; 0 THEN 'Promo only'
        ELSE 'No discount'
    END</CommandText>
      </Query>
      <Fields>
        <Field Name="discount_type">
          <DataField>discount_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ride_count">
          <DataField>ride_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="net_revenue">
          <DataField>net_revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="avg_gross_fare">
          <DataField>avg_gross_fare</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
